---
import { Phone, EnvelopeSimple } from '@phosphor-icons/react';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.svg';
---

<section id="contacts" class="py-24 bg-bg-base relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <div class="glass-panel rounded-[3rem] p-12 lg:p-20 relative overflow-hidden">
        {/* Background Decorative Mesh */}
        <div class="absolute top-0 right-0 w-[50%] h-full bg-gradient-to-l from-brand-dark/[0.03] to-transparent -z-10"></div>
        <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-brand-accent/10 rounded-full blur-[100px] -z-10"></div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-10 animate-reveal">
                <div class="space-y-4">
                    <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter leading-none text-text-base">
                        Свяжитесь <span class="text-brand-dark">с нами</span>
                    </h2>
                    <p class="text-lg text-text-muted max-w-[45ch]">
                        Мы всегда готовы к диалогу, сотрудничеству и поддержке членов Ассоциации по любым профессиональным вопросам.
                    </p>
                </div>

                <div class="space-y-6">
                    <div class="flex flex-col gap-6">
                        <div class="flex items-center gap-6 group animate-reveal delay-200">
                            <div class="w-14 h-14 bg-brand-dark rounded-2xl flex items-center justify-center shadow-xl shadow-brand-dark/20 transition-transform group-hover:scale-110">
                                <Phone size={32} className="text-white" weight="fill" />
                            </div>
                            <div class="flex flex-col gap-1">
                                <div class="text-[10px] uppercase font-black tracking-widest text-brand-accent opacity-70">Телефоны</div>
                                <a href="tel:+79060666446" class="text-xl font-bold text-text-base hover:text-brand-red transition-colors">+7 (906) 066-64-46</a>
                                <a href="tel:+79151796054" class="text-xl font-bold text-text-base hover:text-brand-red transition-colors">+7 (915) 179-60-54</a>
                            </div>
                        </div>

                        <div class="flex items-center gap-6 group animate-reveal delay-300">
                            <div class="w-14 h-14 bg-brand-accent rounded-2xl flex items-center justify-center shadow-xl shadow-brand-accent/20 transition-transform group-hover:scale-110">
                                <EnvelopeSimple size={32} className="text-brand-dark" weight="bold" />
                            </div>
                            <div>
                                <div class="text-[10px] uppercase font-black tracking-widest text-brand-dark/50">E-mail адрес</div>
                                <a href="mailto:mavhpmoscow@yandex.ru" class="text-xl font-bold text-text-base hover:text-brand-red transition-colors underline decoration-brand-dark/10 decoration-2 underline-offset-4">mavhpmoscow@yandex.ru</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="hidden lg:block relative animate-reveal delay-500">
                <div class="relative w-full aspect-square glass-panel rounded-[2.5rem] overflow-hidden border-brand-dark/5 shadow-inner">
                    <div class="absolute inset-0 bg-gradient-to-tr from-brand-dark/10 to-brand-accent/5"></div>
                    <div class="absolute inset-0 flex items-center justify-center p-20">
                         <Image src={logoImg} alt="АВХП" class="w-full h-auto opacity-10 blur-[1px] absolute scale-150 rotate-12" />
                         <div class="relative text-center space-y-6">
                            <div class="mx-auto flex flex-col items-center justify-center space-y-4">
                                <Image src={logoImg} alt="MAVHL Logo" class="w-64 h-auto drop-shadow-2xl" />
                                <div class="text-4xl font-black tracking-tighter text-brand-dark leading-none">MAVHL</div>
                                <div class="text-xs uppercase font-bold tracking-[0.3em] text-brand-accent">Moscow Department</div>
                            </div>
                         </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
  </div>
</section>
